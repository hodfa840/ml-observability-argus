{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Argus: Start (API + Dashboard + Simulation)",
      "type": "shell",
      "command": ".venv\\Scripts\\python run.py",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": true
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Argus: Start (API + Dashboard only)",
      "type": "shell",
      "command": ".venv\\Scripts\\python run.py --no-sim",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "Argus: API only",
      "type": "shell",
      "command": ".venv\\Scripts\\python -m uvicorn app:app --reload --port 8000",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Argus: Dashboard only",
      "type": "shell",
      "command": ".venv\\Scripts\\python -m streamlit run dashboard/app.py",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    }
  ]
}
